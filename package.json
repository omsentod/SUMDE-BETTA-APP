{
  "name": "sumde-betta-app-monorepo",
  "version": "1.0.0",
  "scripts": {
    "install:all": "npm install --prefix sumde-frontend && npm install --prefix sumde-backend",
    "dev:frontend": "npm run dev --prefix sumde-frontend",
    "dev:backend": "npm run dev --prefix sumde-backend",
    "dev": "npx concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "db:push": "npm run db:push --prefix sumde-backend",
    "db:seed": "npm run db:seed --prefix sumde-backend",
    "db:studio": "npx prisma studio --schema=sumde-backend/prisma/schema.prisma",
    "build:frontend": "npm run build --prefix sumde-frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
